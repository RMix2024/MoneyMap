<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MoneyMap.MainPage">



    <VerticalStackLayout Padding="20">

     
        <Border Stroke="Gray" StrokeThickness="2" BackgroundColor="#D6EAF8"
        Margin="5" Padding="15" WidthRequest="350"
        StrokeShape="RoundRectangle 10">
            <VerticalStackLayout>
                <Label Text="Total Balance" FontSize="20" FontAttributes="Bold"
               HorizontalOptions="Center" TextColor="DarkBlue"/>

                <Label Text="{Binding TotalBalance, StringFormat='${0:F2}'}"
               FontSize="28" FontAttributes="Bold" TextColor="DarkGreen"
               HorizontalOptions="Center"/>

                <Grid Padding="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <!-- Income Label -->
                    <Border Stroke="Black" StrokeThickness="1" BackgroundColor="#B8E994"
                    Padding="8" StrokeShape="RoundRectangle 5"
                    HorizontalOptions="Center">
                        <Label Text="Income" FontSize="16" FontAttributes="Bold"
                       TextColor="Black" HorizontalOptions="Center"/>
                    </Border>

                    <!-- Expenses Label -->
                    <Border Stroke="Black" StrokeThickness="1" BackgroundColor="#FFADAD"
                    Padding="8" StrokeShape="RoundRectangle 5"
                    HorizontalOptions="Center" Grid.Column="1">
                        <Label Text="Expenses" FontSize="16" FontAttributes="Bold"
                       TextColor="Black" HorizontalOptions="Center"/>
                    </Border>

                    <Label Text="{Binding TotalIncome, StringFormat='${0:F2}'}" FontSize="18"
                   Grid.Column="0" TextColor="Green" HorizontalOptions="Center"/>
                    <Label Text="{Binding TotalExpenses, StringFormat='-${0:F2}'}" FontSize="18"
                   Grid.Column="1" TextColor="Red" HorizontalOptions="Center"/>
                </Grid>
            </VerticalStackLayout>
        </Border>

     

    </VerticalStackLayout>


</ContentPage>
