<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:microcharts="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui"
             x:Class="MoneyMap.MainPage"
             BackgroundColor="#181818">

    <ScrollView
        BackgroundColor="#181818"
            HorizontalOptions="Fill"
            VerticalOptions="Fill">
        
        <VerticalStackLayout Padding="20" Spacing="15" WidthRequest="500" HorizontalOptions="Center">

            <!-- Total Balance -->
            <Border BackgroundColor="#E3F2FD" StrokeThickness="0" StrokeShape="RoundRectangle 15">
                <VerticalStackLayout Padding="15">
                    <Label Text="Total Balance"
                       FontAttributes="Bold"
                       FontSize="20"
                       TextColor="Blue"
                       HorizontalOptions="Center"/>
                    <Label Text="{Binding TotalBalance, StringFormat='{}{0:C}'}"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="{Binding TotalBalance, Converter={StaticResource BalanceColorConverter}}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>

            <!-- Income vs Expenses Chart -->
            <Border StrokeThickness="1" Stroke="#333" StrokeShape="RoundRectangle 15">
                <VerticalStackLayout Padding="10">
                    <Label Text="Income vs Expenses"
                           FontAttributes="Bold"
                           FontSize="18"
                           TextColor="White"
                           HorizontalOptions="Center"/>
                    <microcharts:ChartView Chart="{Binding IncomeVsExpenseChart}"
                                           HeightRequest="180"
                                           WidthRequest="300"
                                           HorizontalOptions="Center"
                                           BackgroundColor="Transparent"/>
                </VerticalStackLayout>
            </Border>

            <!-- Expense Breakdown Pie Chart -->
            <Border BackgroundColor="Transparent" StrokeThickness="1" Stroke="#333" StrokeShape="RoundRectangle 10" Padding="10">
                <VerticalStackLayout>
                    <Label Text="Expense Breakdown"
                           FontSize="16"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="White" />
                    <microcharts:ChartView Chart="{Binding ExpenseBreakdownChart}"
                                           HeightRequest="200"
                                           BackgroundColor="white"/>
                </VerticalStackLayout>
            </Border>

            <!-- Recent Transactions -->
            <Label Text="Recent Transactions" BackgroundColor="White"
                   FontAttributes="Bold" 
                   FontSize="18" 
                   TextColor="White" 
                   HorizontalOptions="Center"
                   Margin="10"/>

            <CollectionView ItemsSource="{Binding RecentTransactions}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="#1E1E1E" StrokeThickness="1" Stroke="#333" StrokeShape="RoundRectangle 10" Margin="5">
                            <Grid Padding="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Label Text="{Binding Description}"
                                       FontSize="16"
                                       VerticalOptions="Center"
                                       TextColor="White"
                                       Grid.Column="0"/>

                                <Label Text="{Binding Amount, StringFormat='{}{0:C}'}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="End"
                                       TextColor="{Binding Type, Converter={StaticResource TransactionTypeColorConverter}}"
                                       Grid.Column="1"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
